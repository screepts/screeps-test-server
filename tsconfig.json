{
  "compilerOptions": {
    "module": "nodenext",
    "lib": [
      "ESNext"
    ],
    "target": "esnext",
    "moduleResolution": "nodenext",
    "outDir": "dist",
    "allowJs": true,
    "declaration": true,
    "strict": true,
    "noImplicitReturns": true,
    "allowSyntheticDefaultImports": true,
    "allowUnreachableCode": false,
    "types": ["screeps", "mocha"]
  },
  "exclude": [
    "node_modules"
  ],
  "include": [
    "src/",
    "utils/",
    "test/",
  ]
}
